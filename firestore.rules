rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Identity Verification (Pillar 6 & 2)
    function isVerified() { 
      return isSignedIn() && 
             request.auth.token.email_verified == true; 
    }

    // --- Validation Blueprints (Pillar 2) ---
    function isValidUser(data) {
      return data.userId is string && data.userId.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.totalPoints is int &&
             data.rank in ["Novice", "Adept", "Expert", "Master"] &&
             data.rating is int;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Pillar 8: Forbidden
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) &&
                      incoming().userId == userId &&
                      incoming().totalPoints == 0;
                      
      allow update: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) &&
                      incoming().userId == userId &&
                      incoming().totalPoints >= existing().totalPoints &&
                      // Action-based updates (Pillar 4)
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'displayName', 'photoURL', 'totalPoints', 'rank', 'rating', 'streak', 'lastActive', 
                        'currentQuizIndex', 'currentQuizScore', 'email'
                      ]);
    }

    // 2. Activity Logs
    match /activity_logs/{logId} {
      // Pillar 8: Secure List Queries
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(incoming().userId) &&
                      incoming().userId == request.auth.uid &&
                      incoming().pointsEarned > 0 &&
                      incoming().timestamp == request.time;
      
      allow update, delete: if false; // Logs are immutable
    }

    // 3. Quiz Scores
    match /quiz_scores/{scoreId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().timestamp == request.time;
                      
      allow update, delete: if false;
    }
  }
}
