rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other users
      allow create: if isOwner(userId) && 
                      incoming().userId == userId &&
                      incoming().totalPoints == 0 &&
                      incoming().rank == "Novice" &&
                      incoming().rating == 0 &&
                      incoming().streak == 0;
      allow update: if isOwner(userId) && 
                      incoming().userId == userId &&
                      // Prevent totalPoints from decreasing manually
                      incoming().totalPoints >= existing().totalPoints &&
                      // Action-based updates using diff()
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'displayName', 'photoURL', 'totalPoints', 'rank', 'rating', 'streak', 'lastActive'
                      ]);
    }

    // 2. Quiz Scores
    match /quiz_scores/{scoreId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().score >= 0 &&
                      incoming().timestamp == request.time;
    }

    // 3. Activity Logs
    match /activity_logs/{logId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().pointsEarned > 0;
    }
  }
}
