{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user ranking, points, and account metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalPoints": { "type": "integer" },
        "rank": { "type": "string", "enum": ["Novice", "Adept", "Expert", "Master"] },
        "rating": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "totalPoints", "rank"]
    },
    "QuizScore": {
      "title": "Quiz Result",
      "description": "Records individual quiz attempts and scores.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "score": { "type": "integer" },
        "maxScore": { "type": "integer" },
        "percentage": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "score", "timestamp"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Tracks daily engagement for growth graphs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "pointsEarned": { "type": "integer" },
        "type": { "type": "string", "enum": ["quiz", "simulator", "reading"] }
      },
      "required": ["userId", "date", "pointsEarned"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile records."
    },
    "/quiz_scores/{scoreId}": {
      "schema": "QuizScore",
      "description": "Historical quiz scores."
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Daily engagement logs."
    }
  }
}
